{
	"name": "shoebox",
	"version": "0.1.0",
	"private": true,
	"license": "AGPL-3.0-only",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "PLATFORM=node vite build",
		"build:cf": "PLATFORM=cloudflare vite build",
		"build:worker": "node scripts/build-worker.mjs",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:workers": "vitest run --config vitest.workers.config.ts",
		"test:e2e": "pnpm fixtures && playwright test",
		"test:e2e:cf": "pnpm fixtures && playwright test -c playwright.cf.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate:d1": "wrangler d1 migrations apply shoebox-db --local",
		"db:migrate:d1:remote": "wrangler d1 migrations apply shoebox-db --remote",
		"db:migrate": "node scripts/migrate.mjs",
		"db:reindex": "tsx scripts/db-reindex.ts",
		"faces:backfill": "tsx scripts/faces-backfill.ts",
		"fixtures": "tsx e2e/fixtures/generate.ts",
		"worker": "tsx src/worker/index.ts"
	},
	"dependencies": {
		"@fontsource-variable/archivo": "^5.2.0",
		"@fontsource-variable/fraunces": "^5.2.0",
		"@noble/hashes": "^2.2.0",
		"archiver": "^8.0.0",
		"aws4fetch": "^1.0.20",
		"better-sqlite3": "^12.2.0",
		"blurhash": "^2.0.5",
		"chokidar": "^5.0.0",
		"drizzle-orm": "^0.44.2",
		"exifr": "^7.1.3",
		"ffmpeg-static": "^5.3.0",
		"ffprobe-static": "^3.1.0",
		"file-type": "^22.0.1",
		"fluent-ffmpeg": "^2.1.3",
		"isomorphic-dompurify": "^3.18.0",
		"marked": "^18.0.5",
		"nanoid": "^5.1.0",
		"sharp": "^0.35.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@cloudflare/vitest-pool-workers": "^0.8.19",
		"@cloudflare/workers-types": "^4.20260620.0",
		"@eslint/js": "^9.28.0",
		"@playwright/test": "^1.53.0",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@types/archiver": "^8.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/fluent-ffmpeg": "^2.1.28",
		"@types/node": "^22.15.0",
		"drizzle-kit": "^0.31.1",
		"esbuild": "^0.23.1",
		"eslint": "^9.28.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-svelte": "^3.9.0",
		"globals": "^16.2.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.34.0",
		"svelte-check": "^4.2.1",
		"tsx": "^4.20.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.34.0",
		"vite": "^6.3.5",
		"vitest": "^3.2.4",
		"wrangler": "^4.20.0"
	}
}
