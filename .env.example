# Build target and runtime app configuration (Contract 8 app env names).
PLATFORM=node
DATABASE_PATH=/data/shoebox.db
MEDIA_PATH=/media
INGEST_PATH=/ingest
ORIGIN=http://localhost:3000
BODY_LIMIT_MB=4096
FACES_ENABLED=0

# Nightly backup retention: db-backup.mjs prunes snapshots older than this many days.
BACKUP_KEEP_DAYS=14
# Nightly cleanup: trash-sweep.mjs purges abandoned chunked-upload tmp trees older
# than this many hours. 0 disables the sweep.
UPLOAD_TMP_TTL_HOURS=24

# Docker compose host-directory interpolation (which host paths back /data, /media, /ingest).
SHOEBOX_DATA_DIR=./data
SHOEBOX_MEDIA_DIR=./media
SHOEBOX_INGEST_DIR=./ingest
